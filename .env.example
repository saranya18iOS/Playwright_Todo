# Copy this file to .env — .env is git-ignored

# Anthropic API key (enables MCP dynamic test data)
# Without this, the suite uses local static data automatically
ANTHROPIC_API_KEY=your_api_key_here

# Environment selection: dev | staging | prod  (default: dev)
ENV=dev

# Override base URL directly (optional — takes precedence over ENV)
# BASE_URL=https://demo.playwright.dev/todomvc

# Browser visibility: set to "false" to show browser window
HEADLESS=true

# Slow down actions by N ms (useful for demos)
SLOW_MO=0

# Verbose driver + page logging
# LOG_LEVEL=debug
